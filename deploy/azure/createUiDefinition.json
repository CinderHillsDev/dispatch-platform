{
  "$schema": "https://schema.management.azure.com/schemas/0.1.2-preview/CreateUIDefinition.MultiVm.json#",
  "handler": "Microsoft.Azure.CreateUIDef",
  "version": "0.1.2-preview",
  "parameters": {
    "basics": [
      {
        "name": "vmName",
        "type": "Microsoft.Common.TextBox",
        "label": "VM name",
        "defaultValue": "dispatch",
        "toolTip": "Names the virtual machine and its related resources.",
        "constraints": { "required": true, "regex": "^[a-z][a-z0-9-]{1,30}[a-z0-9]$", "validationMessage": "3-32 chars: lowercase letters, digits and hyphens; must start with a letter." }
      },
      {
        "name": "adminUsername",
        "type": "Microsoft.Compute.UserNameTextBox",
        "label": "Admin username",
        "defaultValue": "azureuser",
        "toolTip": "Linux admin username for SSH.",
        "osPlatform": "Linux",
        "constraints": { "required": true }
      },
      {
        "name": "adminCredentials",
        "type": "Microsoft.Compute.CredentialsCombo",
        "label": {
          "authenticationType": "Authentication type",
          "password": "Password",
          "confirmPassword": "Confirm password",
          "sshPublicKey": "SSH public key"
        },
        "toolTip": {
          "authenticationType": "SSH public key (recommended) or password for the Linux VM.",
          "sshPublicKey": "Paste your SSH public key.",
          "password": "Admin password for the Linux VM."
        },
        "osPlatform": "Linux",
        "constraints": { "required": true }
      },
      {
        "name": "dispatchAdminPassword",
        "type": "Microsoft.Common.PasswordBox",
        "label": { "password": "Dashboard admin password", "confirmPassword": "Confirm password" },
        "toolTip": "Password to log in to the Dispatch dashboard at https://<host>:8420.",
        "constraints": { "required": true },
        "options": { "hideConfirmation": false }
      }
    ],
    "steps": [
      {
        "name": "vmConfig",
        "label": "VM",
        "elements": [
          {
            "name": "vmSize",
            "type": "Microsoft.Compute.SizeSelector",
            "label": "VM size",
            "toolTip": "Standard_B2s (2 vCPU / 4 GB) is a fine starting point.",
            "recommendedSizes": [ "Standard_B2s", "Standard_B2ms", "Standard_D2s_v5" ],
            "osPlatform": "Linux",
            "imageReference": { "publisher": "Canonical", "offer": "ubuntu-24_04-lts", "sku": "server" },
            "count": 1
          },
          {
            "name": "dispatchVersion",
            "type": "Microsoft.Common.TextBox",
            "label": "Dispatch version",
            "defaultValue": "0.7.0",
            "toolTip": "Release version to install (a GitHub release tag without the leading 'v').",
            "constraints": { "required": true, "regex": "^[0-9]+\\.[0-9]+\\.[0-9]+$", "validationMessage": "Use a semantic version like 0.7.0." }
          }
        ]
      },
      {
        "name": "network",
        "label": "Networking",
        "elements": [
          {
            "name": "vnetNewOrExisting",
            "type": "Microsoft.Common.OptionsGroup",
            "label": "Virtual network",
            "defaultValue": "Create new",
            "toolTip": "Create a new VNet, or deploy the VM into an existing one.",
            "constraints": {
              "allowedValues": [
                { "label": "Create new", "value": "new" },
                { "label": "Use existing", "value": "existing" }
              ],
              "required": true
            }
          },

          {
            "name": "newVnetName",
            "type": "Microsoft.Common.TextBox",
            "label": "New virtual network name",
            "defaultValue": "dispatch-vnet",
            "toolTip": "Name for the VNet that will be created.",
            "visible": "[equals(steps('network').vnetNewOrExisting, 'new')]",
            "constraints": { "required": "[equals(steps('network').vnetNewOrExisting, 'new')]", "regex": "^[a-zA-Z0-9][a-zA-Z0-9._-]{1,62}[a-zA-Z0-9_]$", "validationMessage": "2-64 chars: letters, digits, '.', '_', '-'." }
          },
          {
            "name": "newVnetPrefix",
            "type": "Microsoft.Common.TextBox",
            "label": "New VNet address space (CIDR)",
            "defaultValue": "10.20.0.0/16",
            "toolTip": "Address space for the new VNet.",
            "visible": "[equals(steps('network').vnetNewOrExisting, 'new')]",
            "constraints": { "required": "[equals(steps('network').vnetNewOrExisting, 'new')]", "regex": "^([0-9]{1,3}\\.){3}[0-9]{1,3}/[0-9]{1,2}$", "validationMessage": "Enter a CIDR like 10.20.0.0/16." }
          },
          {
            "name": "newSubnetName",
            "type": "Microsoft.Common.TextBox",
            "label": "New subnet name",
            "defaultValue": "default",
            "toolTip": "Name for the subnet created in the new VNet.",
            "visible": "[equals(steps('network').vnetNewOrExisting, 'new')]",
            "constraints": { "required": "[equals(steps('network').vnetNewOrExisting, 'new')]" }
          },
          {
            "name": "newSubnetPrefix",
            "type": "Microsoft.Common.TextBox",
            "label": "New subnet address range (CIDR)",
            "defaultValue": "10.20.0.0/24",
            "toolTip": "Address range for the subnet in the new VNet (must sit inside the VNet address space).",
            "visible": "[equals(steps('network').vnetNewOrExisting, 'new')]",
            "constraints": { "required": "[equals(steps('network').vnetNewOrExisting, 'new')]", "regex": "^([0-9]{1,3}\\.){3}[0-9]{1,3}/[0-9]{1,2}$", "validationMessage": "Enter a CIDR like 10.20.0.0/24." }
          },

          {
            "name": "rgApi",
            "type": "Microsoft.Solutions.ArmApiControl",
            "request": {
              "method": "GET",
              "path": "[concat(subscription().id, '/resourcegroups?api-version=2021-04-01')]"
            }
          },
          {
            "name": "existingVnetRg",
            "type": "Microsoft.Common.DropDown",
            "label": "Virtual network resource group",
            "toolTip": "Resource group that contains your existing VNet.",
            "filter": true,
            "visible": "[equals(steps('network').vnetNewOrExisting, 'existing')]",
            "constraints": {
              "required": "[equals(steps('network').vnetNewOrExisting, 'existing')]",
              "allowedValues": "[map(steps('network').rgApi.value, (item) => parse(concat('{\"label\":\"', item.name, '\",\"value\":\"', item.name, '\"}')))]"
            }
          },
          {
            "name": "vnetApi",
            "type": "Microsoft.Solutions.ArmApiControl",
            "request": {
              "method": "GET",
              "path": "[concat(subscription().id, '/resourceGroups/', steps('network').existingVnetRg, '/providers/Microsoft.Network/virtualNetworks?api-version=2023-11-01')]"
            }
          },
          {
            "name": "existingVnet",
            "type": "Microsoft.Common.DropDown",
            "label": "Virtual network",
            "toolTip": "Existing VNet to deploy the VM into.",
            "filter": true,
            "visible": "[equals(steps('network').vnetNewOrExisting, 'existing')]",
            "constraints": {
              "required": "[equals(steps('network').vnetNewOrExisting, 'existing')]",
              "allowedValues": "[map(steps('network').vnetApi.value, (item) => parse(concat('{\"label\":\"', item.name, '\",\"value\":\"', item.name, '\"}')))]"
            }
          },
          {
            "name": "subnetApi",
            "type": "Microsoft.Solutions.ArmApiControl",
            "request": {
              "method": "GET",
              "path": "[concat(subscription().id, '/resourceGroups/', steps('network').existingVnetRg, '/providers/Microsoft.Network/virtualNetworks/', steps('network').existingVnet, '/subnets?api-version=2023-11-01')]"
            }
          },
          {
            "name": "existingSubnet",
            "type": "Microsoft.Common.DropDown",
            "label": "Subnet",
            "toolTip": "Subnet in the selected VNet to place the VM's network interface in.",
            "filter": true,
            "visible": "[equals(steps('network').vnetNewOrExisting, 'existing')]",
            "constraints": {
              "required": "[equals(steps('network').vnetNewOrExisting, 'existing')]",
              "allowedValues": "[map(steps('network').subnetApi.value, (item) => parse(concat('{\"label\":\"', item.name, '\",\"value\":\"', item.name, '\"}')))]"
            }
          },

          {
            "name": "submissionSource",
            "type": "Microsoft.Common.TextBox",
            "label": "Submission source",
            "defaultValue": "VirtualNetwork",
            "toolTip": "Who may reach the SMTP (25/587) and HTTP API (8025) submission ports. 'VirtualNetwork' (default) keeps them off the internet. Set a CIDR (e.g. 203.0.113.0/24), or 'Internet' only if you accept the risk.",
            "constraints": { "required": true }
          }
        ]
      }
    ],
    "outputs": {
      "vmName": "[basics('vmName')]",
      "adminUsername": "[basics('adminUsername')]",
      "authenticationType": "[basics('adminCredentials').authenticationType]",
      "adminPasswordOrKey": "[if(equals(basics('adminCredentials').authenticationType, 'password'), basics('adminCredentials').password, basics('adminCredentials').sshPublicKey)]",
      "dispatchAdminPassword": "[basics('dispatchAdminPassword')]",
      "vmSize": "[steps('vmConfig').vmSize]",
      "dispatchVersion": "[steps('vmConfig').dispatchVersion]",
      "submissionSource": "[steps('network').submissionSource]",
      "vnetNewOrExisting": "[steps('network').vnetNewOrExisting]",
      "vnetName": "[if(equals(steps('network').vnetNewOrExisting, 'existing'), steps('network').existingVnet, steps('network').newVnetName)]",
      "vnetResourceGroup": "[if(equals(steps('network').vnetNewOrExisting, 'existing'), steps('network').existingVnetRg, '')]",
      "vnetAddressPrefix": "[if(equals(steps('network').vnetNewOrExisting, 'new'), steps('network').newVnetPrefix, '10.20.0.0/16')]",
      "subnetName": "[if(equals(steps('network').vnetNewOrExisting, 'existing'), steps('network').existingSubnet, steps('network').newSubnetName)]",
      "subnetAddressPrefix": "[if(equals(steps('network').vnetNewOrExisting, 'new'), steps('network').newSubnetPrefix, '10.20.0.0/24')]",
      "location": "[location()]"
    }
  }
}
