{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "description": "Deploys Dispatch (open-source SMTP relay) on a single Ubuntu 24.04 VM. cloud-init runs the official install.sh, which installs PostgreSQL and Dispatch as a systemd service. Open source, Apache-2.0."
  },
  "parameters": {
    "vmName": {
      "type": "string",
      "defaultValue": "dispatch",
      "metadata": { "description": "Name for the virtual machine and related resources." }
    },
    "adminUsername": {
      "type": "string",
      "defaultValue": "azureuser",
      "metadata": { "description": "Linux admin username (for SSH into the VM)." }
    },
    "authenticationType": {
      "type": "string",
      "defaultValue": "sshPublicKey",
      "allowedValues": [ "sshPublicKey", "password" ],
      "metadata": { "description": "SSH admin auth type. An SSH public key is recommended." }
    },
    "adminPasswordOrKey": {
      "type": "securestring",
      "metadata": { "description": "SSH public key (authenticationType=sshPublicKey) or admin password (authenticationType=password) for the Linux VM." }
    },
    "dispatchAdminPassword": {
      "type": "securestring",
      "metadata": { "description": "Dashboard admin password (used to log in at https://<host>:8420 after deployment)." }
    },
    "vmSize": {
      "type": "string",
      "defaultValue": "Standard_B2s",
      "metadata": { "description": "VM size. Standard_B2s (2 vCPU / 4 GB) is a fine starting point." }
    },
    "dispatchVersion": {
      "type": "string",
      "defaultValue": "0.5.0",
      "metadata": { "description": "Dispatch release version to install (matches a GitHub release tag without the leading 'v')." }
    },
    "submissionSource": {
      "type": "string",
      "defaultValue": "VirtualNetwork",
      "metadata": { "description": "Who may reach the mail-submission ports (SMTP 25/587 and the HTTP API 8025). Defaults to 'VirtualNetwork' - only resources in this VM's VNet, so it is NOT exposed to the internet. Set to a specific CIDR (e.g. 203.0.113.0/24) if apps send from elsewhere; use 'Internet' only if you fully understand the risk (an internet-exposed mail port is a prime abuse target)." }
    },
    "vnetNewOrExisting": {
      "type": "string",
      "defaultValue": "new",
      "allowedValues": [ "new", "existing" ],
      "metadata": { "description": "Create a new VNet or deploy the VM into an existing one. Choose 'existing' to reuse a VNet you already have (set vnetName, vnetResourceGroup and subnetName to match)." }
    },
    "vnetName": {
      "type": "string",
      "defaultValue": "dispatch-vnet",
      "metadata": { "description": "VNet name. For vnetNewOrExisting='new' the VNet is created with this name; for 'existing' it must match the name of your existing VNet." }
    },
    "vnetResourceGroup": {
      "type": "string",
      "defaultValue": "",
      "metadata": { "description": "Resource group of an existing VNet (only used when vnetNewOrExisting='existing'). Leave blank to use this deployment's resource group." }
    },
    "vnetAddressPrefix": {
      "type": "string",
      "defaultValue": "10.20.0.0/16",
      "metadata": { "description": "Address space for a new VNet (ignored when vnetNewOrExisting='existing')." }
    },
    "subnetName": {
      "type": "string",
      "defaultValue": "default",
      "metadata": { "description": "Subnet the VM's NIC is placed in. For a new VNet it is created; for an existing VNet it must already exist." }
    },
    "subnetAddressPrefix": {
      "type": "string",
      "defaultValue": "10.20.0.0/24",
      "metadata": { "description": "Address range for the subnet in a new VNet (ignored when vnetNewOrExisting='existing')." }
    },
    "dnsLabelPrefix": {
      "type": "string",
      "defaultValue": "",
      "metadata": { "description": "Globally-unique DNS label for the public IP (becomes <label>.<region>.cloudapp.azure.com). Leave blank to auto-generate one from the VM name." }
    },
    "location": {
      "type": "string",
      "defaultValue": "",
      "metadata": { "description": "Azure region for all resources. Leave blank to use the resource group's region." }
    }
  },
  "variables": {
    "nsgName": "[concat(parameters('vmName'), '-nsg')]",
    "pipName": "[concat(parameters('vmName'), '-pip')]",
    "nicName": "[concat(parameters('vmName'), '-nic')]",
    "loc": "[if(empty(parameters('location')), resourceGroup().location, parameters('location'))]",
    "dnsLabel": "[if(empty(parameters('dnsLabelPrefix')), toLower(concat(parameters('vmName'), '-', uniqueString(resourceGroup().id))), parameters('dnsLabelPrefix'))]",
    "createVnet": "[equals(parameters('vnetNewOrExisting'), 'new')]",
    "vnetRg": "[if(empty(parameters('vnetResourceGroup')), resourceGroup().name, parameters('vnetResourceGroup'))]",
    "subnetRef": "[resourceId(variables('vnetRg'), 'Microsoft.Network/virtualNetworks/subnets', parameters('vnetName'), parameters('subnetName'))]",
    "linuxConfiguration": {
      "disablePasswordAuthentication": true,
      "ssh": {
        "publicKeys": [
          {
            "path": "[concat('/home/', parameters('adminUsername'), '/.ssh/authorized_keys')]",
            "keyData": "[parameters('adminPasswordOrKey')]"
          }
        ]
      }
    },
    "cloudInit": "[base64(concat('#!/bin/bash\nset -euo pipefail\nexport DEBIAN_FRONTEND=noninteractive\nVER=', parameters('dispatchVersion'), '\nADMIN_PW=$(printf %s ', base64(parameters('dispatchAdminPassword')), ' | base64 -d)\nDB_PW=$(openssl rand -hex 24)\napt-get update -y\napt-get install -y curl tar openssl\ncd /root\ncurl -fSL https://github.com/CinderHillsDev/dispatch-platform/releases/download/v${VER}/dispatch-${VER}-linux.tar.gz -o dispatch.tar.gz\ntar -xzf dispatch.tar.gz\ncd dispatch-${VER}-linux\n./install.sh --install-postgres --db-password ${DB_PW} --admin-password \"${ADMIN_PW}\" --generate-cert\n'))]"
  },
  "resources": [
    {
      "type": "Microsoft.Network/networkSecurityGroups",
      "apiVersion": "2023-09-01",
      "name": "[variables('nsgName')]",
      "location": "[variables('loc')]",
      "properties": {
        "securityRules": [
          {
            "name": "SSH",
            "properties": { "priority": 1000, "direction": "Inbound", "access": "Allow", "protocol": "Tcp", "sourceAddressPrefix": "*", "sourcePortRange": "*", "destinationAddressPrefix": "*", "destinationPortRange": "22" }
          },
          {
            "name": "Dashboard-HTTPS",
            "properties": { "priority": 1010, "direction": "Inbound", "access": "Allow", "protocol": "Tcp", "sourceAddressPrefix": "*", "sourcePortRange": "*", "destinationAddressPrefix": "*", "destinationPortRange": "8420" }
          },
          {
            "name": "SMTP-Submission",
            "properties": { "priority": 1020, "direction": "Inbound", "access": "Allow", "protocol": "Tcp", "sourceAddressPrefix": "[parameters('submissionSource')]", "sourcePortRange": "*", "destinationAddressPrefix": "*", "destinationPortRanges": [ "25", "587" ] }
          },
          {
            "name": "Ingestion-API",
            "properties": { "priority": 1030, "direction": "Inbound", "access": "Allow", "protocol": "Tcp", "sourceAddressPrefix": "[parameters('submissionSource')]", "sourcePortRange": "*", "destinationAddressPrefix": "*", "destinationPortRange": "8025" }
          }
        ]
      }
    },
    {
      "condition": "[variables('createVnet')]",
      "type": "Microsoft.Network/virtualNetworks",
      "apiVersion": "2023-09-01",
      "name": "[parameters('vnetName')]",
      "location": "[variables('loc')]",
      "properties": {
        "addressSpace": { "addressPrefixes": [ "[parameters('vnetAddressPrefix')]" ] },
        "subnets": [
          {
            "name": "[parameters('subnetName')]",
            "properties": {
              "addressPrefix": "[parameters('subnetAddressPrefix')]"
            }
          }
        ]
      }
    },
    {
      "type": "Microsoft.Network/publicIPAddresses",
      "apiVersion": "2023-09-01",
      "name": "[variables('pipName')]",
      "location": "[variables('loc')]",
      "sku": { "name": "Standard" },
      "properties": {
        "publicIPAllocationMethod": "Static",
        "dnsSettings": { "domainNameLabel": "[variables('dnsLabel')]" }
      }
    },
    {
      "type": "Microsoft.Network/networkInterfaces",
      "apiVersion": "2023-09-01",
      "name": "[variables('nicName')]",
      "location": "[variables('loc')]",
      "dependsOn": "[if(variables('createVnet'), createArray(resourceId('Microsoft.Network/networkSecurityGroups', variables('nsgName')), resourceId('Microsoft.Network/publicIPAddresses', variables('pipName')), resourceId('Microsoft.Network/virtualNetworks', parameters('vnetName'))), createArray(resourceId('Microsoft.Network/networkSecurityGroups', variables('nsgName')), resourceId('Microsoft.Network/publicIPAddresses', variables('pipName'))))]",
      "properties": {
        "networkSecurityGroup": { "id": "[resourceId('Microsoft.Network/networkSecurityGroups', variables('nsgName'))]" },
        "ipConfigurations": [
          {
            "name": "ipconfig1",
            "properties": {
              "privateIPAllocationMethod": "Dynamic",
              "subnet": { "id": "[variables('subnetRef')]" },
              "publicIPAddress": { "id": "[resourceId('Microsoft.Network/publicIPAddresses', variables('pipName'))]" }
            }
          }
        ]
      }
    },
    {
      "type": "Microsoft.Compute/virtualMachines",
      "apiVersion": "2023-09-01",
      "name": "[parameters('vmName')]",
      "location": "[variables('loc')]",
      "dependsOn": [ "[resourceId('Microsoft.Network/networkInterfaces', variables('nicName'))]" ],
      "properties": {
        "hardwareProfile": { "vmSize": "[parameters('vmSize')]" },
        "osProfile": {
          "computerName": "[parameters('vmName')]",
          "adminUsername": "[parameters('adminUsername')]",
          "adminPassword": "[parameters('adminPasswordOrKey')]",
          "linuxConfiguration": "[if(equals(parameters('authenticationType'), 'password'), json('null'), variables('linuxConfiguration'))]",
          "customData": "[variables('cloudInit')]"
        },
        "storageProfile": {
          "imageReference": {
            "publisher": "Canonical",
            "offer": "ubuntu-24_04-lts",
            "sku": "server",
            "version": "latest"
          },
          "osDisk": {
            "createOption": "FromImage",
            "managedDisk": { "storageAccountType": "Premium_LRS" }
          }
        },
        "networkProfile": {
          "networkInterfaces": [ { "id": "[resourceId('Microsoft.Network/networkInterfaces', variables('nicName'))]" } ]
        }
      }
    }
  ],
  "outputs": {
    "dashboardUrl": {
      "type": "string",
      "value": "[concat('https://', reference(resourceId('Microsoft.Network/publicIPAddresses', variables('pipName'))).dnsSettings.fqdn, ':8420')]"
    },
    "sshCommand": {
      "type": "string",
      "value": "[concat('ssh ', parameters('adminUsername'), '@', reference(resourceId('Microsoft.Network/publicIPAddresses', variables('pipName'))).dnsSettings.fqdn)]"
    },
    "note": {
      "type": "string",
      "value": "Dispatch installs on first boot (a few minutes). The dashboard uses a self-signed certificate - expect a browser warning. Point apps at the FQDN on port 25/587 (SMTP) or 8025 (HTTP API)."
    }
  }
}
