{
  "Spool": {
    "Directory": "./.dispatch-spool",
    "WorkerCount": 4
  },
  "Listener": {
    "Ports": [ 2525 ],
    "ServerName": "Dispatch",
    "AllowedCidrs": [ "127.0.0.1/32", "::1/128" ],
    "MaxMessageBytes": 0,
    "RequireAuth": false,
    "TlsCertPath": "",
    "TlsCertPassword": ""
  },
  "Retry": {
    "MaxRetries": 3,
    "DelaysSeconds": [ 30, 300, 1800 ]
  },
  "DefaultRelay": {
    "Name": "default",
    "Provider": "Unconfigured",
    "MaxConcurrency": 4,
    "MaxMessageBytes": 0,
    "Settings": {}
  },
  "Api": {
    "Port": 8421,
    "AllowedCidrs": [ "127.0.0.1/32", "::1/128" ],
    "MaxMessageBytes": 0,
    "RateLimitPerKey": 100
  },
  "WebUi": {
    "Port": 8420
  },
  "Purge": {
    "Enabled": true,
    "ScheduleIntervalHours": 6,
    "SpoolFailedRetentionDays": 30,
    "CapturedRetentionDays": 7,
    "Log": {
      "DeliveredRetentionDays": 30,
      "FailedRetentionDays": 90,
      "RetryingRetentionDays": 90,
      "TestSentRetentionDays": 7
    },
    "SizePressure": {
      "TriggerGb": 9.5,
      "TargetGb": 9.0
    }
  }
}
