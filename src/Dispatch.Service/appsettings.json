  },
  "Retry": {
    "MaxRetries": 3,
    "DelaysSeconds": [ 30, 300, 1800 ]
  },
  "DefaultRelay": {
    "Name": "default",
    "Provider": "None",
    "MaxConcurrency": 4,
    "MaxMessageBytes": 0,
    "Settings": {}
  },
  "Api": {
    "Port": 8421,
    "AllowedCidrs": [ "127.0.0.1/32", "::1/128" ],
    "MaxMessageBytes": 0,
    "RateLimitPerKey": 100
  },
  "WebUi": {
    "Port": 8420
  }
}
