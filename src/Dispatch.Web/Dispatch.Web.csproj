<Project Sdk="Microsoft.NET.Sdk">

  <ItemGroup>
    <ProjectReference Include="..\Dispatch.Core\Dispatch.Core.csproj" />
    <ProjectReference Include="..\Dispatch.Data\Dispatch.Data.csproj" />
    <ProjectReference Include="..\Dispatch.Providers\Dispatch.Providers.csproj" />
  </ItemGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.FileProviders.Embedded" Version="10.0.9" />
    <PackageReference Include="MimeKit" Version="4.17.0" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="Dispatch.Web.Tests" />
  </ItemGroup>

  <!-- Embed the compiled React dashboard (src/Dispatch.UI/dist copied to wwwroot) into the assembly.
       Run `npm run build` in ../Dispatch.UI and re-copy wwwroot when the UI changes. -->
  <PropertyGroup>
    <GenerateEmbeddedFilesManifest>true</GenerateEmbeddedFilesManifest>
  </PropertyGroup>

  <ItemGroup>
    <EmbeddedResource Include="wwwroot\**\*" />
  </ItemGroup>

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

</Project>
