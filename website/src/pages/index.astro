---
// Custom landing page (the site's first/home page). Standalone - does not use the Starlight layout -
// so it keeps the existing Tailwind design. All links are base-relative via import.meta.env.BASE_URL,
// so moving to a custom domain (base '/') needs no edits here.
import dashboard from '../assets/dashboard.png';

const base = import.meta.env.BASE_URL; // e.g. "/Dispatch-SMTP-Relay/" (trailing slash included)
const docs = (p = '') => `${base}${p}`;
const gh = 'https://github.com/chrismuench/Dispatch-SMTP-Relay';

const features = [
  {
    title: 'A dozen providers',
    body: 'Mailgun, SendGrid, Amazon SES, Postmark, Resend, SparkPost, SMTP2GO, Maileroo, Bird, Azure - or any SMTP smart host. CC/BCC, attachments, and custom headers everywhere.',
  },
  {
    title: 'Two ways in',
    body: 'Accept mail over SMTP (25 / 587 / 2525, with STARTTLS) or a Mailgun-compatible HTTP/HTTPS API with per-key tokens.',
  },
  {
    title: '📥 Local Inbox - for developers',
    body: 'Test what your app actually sends without delivering anything. Point it at Dispatch, set the relay to Local, and inspect every message - subject, headers, To/Cc/Bcc, rendered HTML & text, and attachments - right in the dashboard. A built-in mail trap, no third-party service.',
    accent: true,
  },
  {
    title: 'Durable spool',
    body: 'Instant 250 OK to a local queue - mail keeps flowing even if the database is down. Auto-retry with back-off; retry failures from the UI.',
  },
  {
    title: 'Smart routing',
    body: 'Route by sender/recipient domain to different providers, with a catch-all default relay and a simulate tool to test rules before they go live.',
  },
  {
    title: 'Live dashboard',
    body: 'Real-time counters and throughput, a searchable/filterable message log with sandboxed HTML preview, daily reports, and one-click provider testing.',
  },
  {
    title: 'Secure by default',
    body: 'HTTPS-only dashboard, a shared TLS cert for SMTP + the API, bcrypt-hashed passwords & API keys, encrypted secrets at rest, and CIDR allow-lists so it’s never an open relay.',
  },
  {
    title: 'Deploy anywhere',
    body: 'Windows & Linux installers (bundled SQL), a multi-arch Docker image, or a ready-to-import virtual appliance for Hyper-V, VMware, KVM & Proxmox. Plus /health and Prometheus /metrics.',
  },
];
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Dispatch SMTP Relay</title>
    <meta
      name="description"
      content="Self-hosted .NET SMTP relay - forward mail from your apps to a dozen providers, capture mail locally for testing, with a durable spool and a live dashboard."
    />
    <link rel="icon" href={docs('favicon.svg')} type="image/svg+xml" />
    <script src="https://cdn.tailwindcss.com" is:inline></script>
  </head>
  <body class="bg-gray-950 text-gray-300 antialiased selection:bg-sky-500/30">
    <div class="mx-auto max-w-5xl px-6">
      <!-- Hero -->
      <header class="pt-20 pb-10 text-center">
        <h1 class="text-5xl sm:text-6xl font-bold tracking-tight text-white">
          Dispatch <span class="text-sky-400">SMTP Relay</span>
        </h1>
        <p class="mt-5 mx-auto max-w-2xl text-lg leading-relaxed text-gray-400">
          A self-hosted SMTP relay for your apps and devices. Point everything at Dispatch and it
          forwards mail to any provider - with a durable queue and a live dashboard.
        </p>
        <div class="mt-8 flex flex-wrap justify-center gap-3">
          <a
            href={docs('start/quickstart/')}
            class="rounded-lg bg-sky-500 px-5 py-2.5 font-semibold text-white shadow hover:bg-sky-400 transition"
          >
            Get started
          </a>
          <a
            href={docs('start/introduction/')}
            class="rounded-lg border border-sky-700 px-5 py-2.5 font-semibold text-sky-200 hover:bg-sky-900/40 transition"
          >
            Documentation
          </a>
          <a
            href={docs('deployment/appliance/')}
            class="rounded-lg border border-sky-700 px-5 py-2.5 font-semibold text-sky-200 hover:bg-sky-900/40 transition"
          >
            Virtual appliance
          </a>
          <a
            href={`${gh}/releases/latest`}
            class="rounded-lg border border-gray-700 px-5 py-2.5 font-semibold text-gray-200 hover:bg-gray-800 transition"
          >
            Download / Releases
          </a>
          <a
            href={gh}
            class="rounded-lg border border-gray-700 px-5 py-2.5 font-semibold text-gray-200 hover:bg-gray-800 transition"
          >
            GitHub
          </a>
        </div>
      </header>

      <!-- Screenshot -->
      <img
        src={dashboard.src}
        width={dashboard.width}
        height={dashboard.height}
        alt="Dispatch dashboard"
        class="w-full rounded-xl border border-gray-800 shadow-2xl"
      />

      <!-- Features -->
      <section class="py-16">
        <h2 class="text-center text-sm font-semibold uppercase tracking-widest text-sky-400">
          What it does
        </h2>
        <div class="mt-8 grid gap-5 sm:grid-cols-2">
          {
            features.map((f) => (
              <div
                class={
                  f.accent
                    ? 'rounded-xl border border-sky-800/60 bg-sky-950/20 p-6'
                    : 'rounded-xl border border-gray-800 bg-gray-900/40 p-6'
                }
              >
                <h3 class="font-semibold text-white">{f.title}</h3>
                <p class="mt-2 text-sm leading-relaxed text-gray-400">{f.body}</p>
              </div>
            ))
          }
        </div>
      </section>

      <!-- Footer -->
      <footer class="border-t border-gray-800 py-8 text-center text-sm text-gray-500">
        <a class="hover:text-gray-300" href={docs('start/introduction/')}>Documentation</a>
        <span class="px-2 text-gray-700">·</span>
        <a class="hover:text-gray-300" href={docs('deployment/overview/')}>Deployment</a>
        <span class="px-2 text-gray-700">·</span>
        <a class="hover:text-gray-300" href={docs('deployment/appliance/')}>Virtual appliance</a>
        <span class="px-2 text-gray-700">·</span>
        <a class="hover:text-gray-300" href={`${gh}/releases/latest`}>Releases</a>
        <span class="px-2 text-gray-700">·</span>
        <a class="hover:text-gray-300" href={gh}>GitHub</a>
        <p class="mt-3 text-gray-600">AGPL-3.0 with Commons Clause</p>
      </footer>
    </div>
  </body>
</html>
