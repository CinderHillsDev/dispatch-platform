<?xml version="1.0" encoding="UTF-8"?>
<!--
  Dispatch SMTP Relay - Windows bundle (WiX v4 Burn).

  Chains the Dispatch MSI, which writes appsettings.json and registers/starts the service. The dashboard
  admin password is set on first run.

  There is no database step. Dispatch defaults to a bundled SQLite file under %ProgramData%\Dispatch, so
  the installer no longer downloads and installs a PostgreSQL server - which was the slowest and most
  failure-prone part of a Windows install, and left a database service behind after uninstall. To use a
  server the site already runs, pass SQLCONN to the MSI; see docs/database.md.

  Build (Windows, WiX v6 toolset):
    1) dotnet publish ..\..\..\src\Dispatch.Service -c Release -o ..\publish
    2) wix build ..\Dispatch.wxs -d PublishDir=..\publish -ext WixToolset.Firewall.wixext -o Dispatch.msi
    3) wix build Bundle.wxs -ext WixToolset.BootstrapperApplications.wixext -ext WixToolset.Util.wixext ^
         -bindpath "Msi=." -o DispatchSetup.exe
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:bal="http://wixtoolset.org/schemas/v4/wxs/bal"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util">

  <!-- Overridden from the git tag by release.yml (`wix build -d Version=1.2.3`); defaults for local builds. -->
  <?ifndef Version?><?define Version="1.0.0"?><?endif?>

  <Bundle Name="Dispatch SMTP Relay"
          Version="$(var.Version)"
          Manufacturer="CinderHills"
          UpgradeCode="3f2a7c10-9b4e-4d2a-8e51-7c0d1a2b3c4d"
          Compressed="yes">

    <BootstrapperApplication>
      <!-- hyperlinkLicense theme with an empty LicenseUrl shows the install UI with no license link.
           LaunchTarget makes the success page show a checked "Launch" button that opens the dashboard in
           the default browser (via `start`), so after clicking Finish the user lands on the dashboard instead
           of being left wondering where the app is. We shell through cmd.exe /c start because LaunchTarget runs
           an executable, not a URL; LaunchHidden keeps the transient cmd window from flashing. -->
      <bal:WixStandardBootstrapperApplication Theme="hyperlinkLicense" LicenseUrl="" SuppressOptionsUI="yes"
                                              LaunchTarget="[SystemFolder]cmd.exe"
                                              LaunchArguments="/c start &quot;&quot; &quot;https://localhost:8420/&quot;"
                                              LaunchHidden="yes" />
    </BootstrapperApplication>


    <Chain>
      <!-- Dispatch MSI. SQLCONN defaults to the bundled SQLite database inside the MSI.
              ARPSYSTEMCOMPONENT=1 hides the MSI so only the bundle shows in Add/Remove Programs. -->
      <MsiPackage Id="DispatchMsi" SourceFile="!(bindpath.Msi)\Dispatch.msi" Vital="yes">
        <MsiProperty Name="ARPSYSTEMCOMPONENT" Value="1" />
      </MsiPackage>
    </Chain>
  </Bundle>
</Wix>
